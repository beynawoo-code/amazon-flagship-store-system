  "erp_publisher_wizard": {
    "version": "1.0",
    "design_goal_zh": "ERP 先选「主投平台 / 预设分类」，再在分类下选具体 Publisher，避免 83 项平铺",
    "ui_pattern": "cascading_picker",
    "fields": {
      "publisher_pick_mode": "recommended | custom_platform | amazon_preset_browse",
      "publisher_category_code": "custom_group_code 或 preset category_code（browse 时）",
      "publisher_name": "最终写入 tag_request，与 Console 一致",
      "console_publisher_mode": "preset | new_custom"
    },
    "step_flow": [
      {
        "step": 1,
        "id": "pick_mode",
        "label_zh": "选择方式",
        "component": "radio_cards"
      },
      {
        "step": 2,
        "id": "category",
        "label_zh": "平台分类",
        "component": "category_grid",
        "depends_on": "pick_mode"
      },
      {
        "step": 3,
        "id": "publisher",
